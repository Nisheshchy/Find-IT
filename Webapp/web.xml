<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

    <display-name>Find It — Lost and Found Platform</display-name>

    <!-- =====================================================
         Welcome File
         ===================================================== -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- =====================================================
         Session Configuration (30 minute timeout)
         ===================================================== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- =====================================================
         Servlet Declarations
         ===================================================== -->

    <!-- Home -->
    <servlet>
        <servlet-name>HomeController</servlet-name>
        <servlet-class>com.findit.controller.HomeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeController</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <!-- About -->
    <servlet>
        <servlet-name>AboutController</servlet-name>
        <servlet-class>com.findit.controller.AboutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AboutController</servlet-name>
        <url-pattern>/about</url-pattern>
    </servlet-mapping>

    <!-- Register -->
    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>com.findit.controller.RegisterController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>com.findit.controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>com.findit.controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Browse Items -->
    <servlet>
        <servlet-name>BrowseController</servlet-name>
        <servlet-class>com.findit.controller.BrowseController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BrowseController</servlet-name>
        <url-pattern>/browse</url-pattern>
    </servlet-mapping>

    <!-- User Dashboard -->
    <servlet>
        <servlet-name>UserDashboardController</servlet-name>
        <servlet-class>com.findit.controller.UserDashboardController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserDashboardController</servlet-name>
        <url-pattern>/user/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Post Item (Lost / Found) -->
    <servlet>
        <servlet-name>ItemController</servlet-name>
        <servlet-class>com.findit.controller.ItemController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemController</servlet-name>
        <url-pattern>/user/post-item</url-pattern>
    </servlet-mapping>

    <!-- User Delete Item -->
    <servlet>
        <servlet-name>UserDeleteItemController</servlet-name>
        <servlet-class>com.findit.controller.UserDeleteItemController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserDeleteItemController</servlet-name>
        <url-pattern>/user/delete-item</url-pattern>
    </servlet-mapping>

    <!-- User Edit Item -->
    <servlet>
        <servlet-name>UserEditItemController</servlet-name>
        <servlet-class>com.findit.controller.UserEditItemController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserEditItemController</servlet-name>
        <url-pattern>/user/edit-item</url-pattern>
    </servlet-mapping>

    <!-- User Profile -->
    <servlet>
        <servlet-name>UserProfileController</servlet-name>
        <servlet-class>com.findit.controller.UserProfileController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfileController</servlet-name>
        <url-pattern>/user/profile</url-pattern>
    </servlet-mapping>

    <!-- User Notifications -->
    <servlet>
        <servlet-name>NotificationController</servlet-name>
        <servlet-class>com.findit.controller.NotificationController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationController</servlet-name>
        <url-pattern>/user/notifications</url-pattern>
    </servlet-mapping>

    <!-- Item Chat -->
    <servlet>
        <servlet-name>ChatController</servlet-name>
        <servlet-class>com.findit.controller.ChatController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChatController</servlet-name>
        <url-pattern>/item/chat</url-pattern>
    </servlet-mapping>

    <!-- Item Detail (Public) -->
    <servlet>
        <servlet-name>ItemDetailController</servlet-name>
        <servlet-class>com.findit.controller.ItemDetailController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemDetailController</servlet-name>
        <url-pattern>/item</url-pattern>
    </servlet-mapping>

    <!-- Admin Dashboard -->
    <servlet>
        <servlet-name>AdminController</servlet-name>
        <servlet-class>com.findit.controller.AdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminController</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Admin Users -->
    <servlet>
        <servlet-name>AdminUserController</servlet-name>
        <servlet-class>com.findit.controller.AdminUserController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserController</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <!-- Admin Items -->
    <servlet>
        <servlet-name>AdminItemController</servlet-name>
        <servlet-class>com.findit.controller.AdminItemController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminItemController</servlet-name>
        <url-pattern>/admin/items</url-pattern>
    </servlet-mapping>

    <!-- Admin Categories -->
    <servlet>
        <servlet-name>AdminCategoryController</servlet-name>
        <servlet-class>com.findit.controller.AdminCategoryController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCategoryController</servlet-name>
        <url-pattern>/admin/categories</url-pattern>
    </servlet-mapping>

    <!-- =====================================================
         Filter Declarations
         ===================================================== -->

    <!-- Auth Filter — protects /user/* -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.findit.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>

    <!-- Admin Filter — protects /admin/* -->
    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.findit.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- =====================================================
         Error Pages
         ===================================================== -->
    <error-page>
        <error-code>404</error-code>
        <location>/jsp/errors/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/jsp/errors/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/jsp/errors/500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/jsp/errors/500.jsp</location>
    </error-page>

</web-app>
